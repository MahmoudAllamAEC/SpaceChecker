
<Window x:Class="SpaceChecker.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SpaceChecker.UI.Views"
        xmlns:converters="clr-namespace:SpaceChecker.UI.Converters"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Window.Resources>
        <!--<converters:StatusToColorConverter x:Key="StatusToColorConverter"/>-->

    </Window.Resources>
    <StackPanel>

        <Button Content="Extract Rooms" Command="{Binding ExtractCommand}" Margin="10"/>
        <Button Content="Import Program" Command="{Binding ImportCommand}" Margin="10"/>
        <Button Content="Run Comparison" Command="{Binding RunComparisonCommand}" Margin="10"/>

        <DataGrid ItemsSource="{Binding Results}" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                
                
                
                <DataGridTextColumn Header="Room" Binding="{Binding RoomName}" Width="180"/>
                <DataGridTextColumn Header="Level" Binding="{Binding Level}" Width="110"/>
                <DataGridTextColumn Header="Required m2" Binding="{Binding RequiredArea , StringFormat=N2}" Width="110"/>
                <DataGridTextColumn Header="Actual m2" Binding="{Binding ActualArea , StringFormat=N2}" Width="110"/>
                <DataGridTextColumn Header="Deviation" Binding="{Binding DeviationText}" Width="100"/>



            </DataGrid.Columns>
        </DataGrid>

    </StackPanel>
    
</Window>
